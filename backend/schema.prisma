generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
  CLIENT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  BROKEN
  RETIRED
  IN_SERVICE
}

enum DeviceCriticality {
  LOW
  MEDIUM
  HIGH
}

enum CredentialCategory {
  ROUTER
  SERVER
  WINDOWS
  EMAIL
  VPN
  WIFI
  DOMAIN
  NAS
  CAMERA
  OTHER
}

enum TicketType {
  INCIDENT
  REQUEST
  MAINTENANCE
  INSTALLATION
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  PENDING
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum TicketSource {
  CLIENT_PORTAL
  INTERNAL
  PHONE
  EMAIL
  QR_SCAN
  AGENT
  IN_PERSON
  MESSAGE
}

enum AgentStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum CrmActivityType {
  PHONE
  EMAIL
  MEETING
  QUOTE
}

enum QuoteStatus {
  NEW
  PREPARING
  SENT
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          Role      @default(TECHNICIAN)
  clientId      String?
  isActive             Boolean   @default(true)
  notificationSettings Json?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  downloadPin   String?
  avatarUrl     String?

  client        Client?   @relation(fields: [clientId], references: [id])

  createdTickets    Ticket[]        @relation("TicketCreatedBy")
  assignedTickets   Ticket[]        @relation("TicketAssignedTo")
  ticketComments    TicketComment[]
  createdCredentials Credential[]
  activityLogs      ActivityLog[]
  assignedDevices      Device[]        @relation("DeviceAssignedUser")
  assignedCredentials  Credential[]    @relation("CredentialUser")
  createdCrmActivities  CrmActivity[] @relation("CrmCreatedBy")
  assignedCrmActivities CrmActivity[] @relation("CrmAssignedTo")
  agentRegistrations    AgentRegistration[] @relation("AgentUser")
  workSessions          WorkSession[] @relation("WorkSessionTech")
  managedClients        Client[]      @relation("ClientManager")
  managedDevices        AgentRegistration[] @relation("DeviceManager")
  managedDevicesDirect  Device[]      @relation("DeviceDirectManager")
  createdTasks  Task[] @relation("TaskCreatedBy")
  assignedTasks Task[] @relation("TaskAssignedTo")
  clientFavorites  ClientFavorite[]
  createdOrders    Order[]         @relation("OrderCreatedBy")
  assignedOrders   Order[]         @relation("OrderAssignedTo")
  createdDelegations Delegation[]  @relation("DelegationCreatedBy")
  assignedDelegations Delegation[] @relation("DelegationAssignedTo")
  techPosition        TechPosition?
  pushSubscriptions   PushSubscription[]
}

model TechPosition {
  id              String   @id @default(uuid())
  userId          String   @unique
  latitude        Float
  longitude       Float
  accuracy        Float?
  nearLocationIds Json?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id            String        @id @default(uuid())
  name          String
  legalName     String?
  taxId         String?
  email         String?
  phone         String?
  website       String?
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  city          String?
  country       String        @default("PL")
  clientType    String        @default("COMPANY")  // COMPANY | INDIVIDUAL
  firstName     String?
  lastName      String?
  notes         String?
  logoUrl       String?
  status        ClientStatus  @default(ACTIVE)
  // Rozliczenie
  billingIntervalMinutes Int  @default(30)
  contractStartDate      DateTime?
  // Umowa serwisowa
  hasContract                  Boolean  @default(false)
  contractHours                Int?
  contractMonthlyValue         Float?
  contractHourlyRateOverLimit  Float?
  contractScope                String?
  contractAttachmentUrl        String?
  hourlyRate                   Float?
  managerId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  manager       User?         @relation("ClientManager", fields: [managerId], references: [id])
  users         User[]
  locations     Location[]
  devices       Device[]
  credentials   Credential[]
  tickets       Ticket[]
  crmActivities CrmActivity[]
  agents        AgentRegistration[]
  workSessions  WorkSession[]
  favorites   ClientFavorite[]
  orders        Order[]
  delegations   Delegation[]
  backupConfigs BackupConfig[]
}

model Location {
  id                    String   @id @default(uuid())
  clientId              String
  name                  String
  type                  String
  addressLine1          String
  addressLine2          String?
  postalCode            String
  city                  String
  country               String   @default("PL")
  contactPersonName     String?
  contactPersonPhone    String?
  contactPersonEmail    String?
  notes                 String?
  latitude              Float?
  longitude             Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  devices       Device[]
  credentials   Credential[]
  tickets       Ticket[]
  crmActivities CrmActivity[]
  workSessions  WorkSession[]
}

model DeviceType {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices   Device[]
}

model Device {
  id                   String            @id @default(uuid())
  clientId             String
  locationId           String
  deviceTypeId         String?
  name                 String
  assetTag             String?
  manufacturer         String?
  model                String?
  serialNumber         String?
  hostname             String?
  ipAddress            String?
  macAddress           String?
  operatingSystem      String?
  osVersion            String?
  warrantyUntil        DateTime?
  purchaseDate         DateTime?
  status               DeviceStatus      @default(ACTIVE)
  criticality          DeviceCriticality @default(MEDIUM)
  qrCodeValue          String            @unique @default(uuid())
  description          String?
  internalNotes        String?
  clientVisibleNotes   String?
  rustdeskId           String?
  rdpAddress           String?
  sshAddress           String?
  anydeskId            String?
  teamviewerId         String?
  customRemoteLink     String?
  assignedUserId       String?
  installationDate     DateTime?
  warrantyMonths       Int?
  gpsLat               Float?
  gpsLon               Float?
  managerId            String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  manager       User?         @relation("DeviceDirectManager", fields: [managerId], references: [id])
  location      Location      @relation(fields: [locationId], references: [id])
  deviceType    DeviceType?   @relation(fields: [deviceTypeId], references: [id])
  assignedUser  User?         @relation("DeviceAssignedUser", fields: [assignedUserId], references: [id])
  credentials   Credential[]
  tickets       Ticket[]
  crmActivities CrmActivity[]
  agents        AgentRegistration[]
  workSessions  WorkSession[]
}

model AccessType {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  icon        String?
  color       String?      @default("#6366f1")
  isSystem    Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  credentials Credential[]
}

model Credential {
  id                String             @id @default(uuid())
  clientId          String
  locationId        String?
  deviceId          String?
  accessTypeId      String?
  userId            String?
  name              String
  category          CredentialCategory @default(OTHER)
  username          String?
  passwordEncrypted String
  urlOrHost         String?
  port              Int?
  additionalData    String?
  notes             String?
  isSharedWithClient Boolean           @default(false)
  createdByUserId   String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location    Location?   @relation(fields: [locationId], references: [id])
  device      Device?     @relation(fields: [deviceId], references: [id])
  createdBy   User        @relation(fields: [createdByUserId], references: [id])
  accessType  AccessType? @relation(fields: [accessTypeId], references: [id])
  user        User?       @relation("CredentialUser", fields: [userId], references: [id])
}

model Ticket {
  id                String        @id @default(uuid())
  ticketNumber      String        @unique
  clientId          String
  locationId        String
  deviceId          String?
  createdByUserId   String
  assignedToUserId  String?
  type              TicketType    @default(INCIDENT)
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus  @default(PENDING)
  source            TicketSource  @default(INTERNAL)
  title             String
  description       String
  resolutionSummary String?
  reportedAt        DateTime      @default(now())
  dueAt             DateTime?
  resolvedAt        DateTime?
  closedAt          DateTime?
  billedInContract  Boolean       @default(false)
  serviceMode       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  reporterName     String?
  reporterPhone    String?

  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location    Location  @relation(fields: [locationId], references: [id])
  device      Device?   @relation(fields: [deviceId], references: [id])
  createdBy   User      @relation("TicketCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo  User?     @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id])
  comments     TicketComment[]
  tasks        Task[]
  orders       Order[]
  workSessions WorkSession[]
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  actionType        String
  description       String
  performedByUserId String?
  metadata          Json?
  createdAt         DateTime @default(now())

  performedBy User? @relation(fields: [performedByUserId], references: [id])
}

model CrmActivity {
  id               String          @id @default(uuid())
  clientId         String
  locationId       String?
  deviceId         String?
  createdByUserId  String
  assignedToUserId String?

  type             CrmActivityType
  title            String?
  occurredAt       DateTime        @default(now())
  notes            String?
  followUpRequired Boolean         @default(false)

  // PHONE
  contactPerson    String?

  // EMAIL
  subject          String?
  attachmentUrls   String?

  // MEETING
  meetingPlace     String?
  participants     String?
  reminderAt       DateTime?

  // QUOTE
  quoteDescription String?
  quoteStatus      QuoteStatus?
  quoteValue       Float?
  quoteAttachmentUrl String?
  linkedTicketId   String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  location   Location? @relation(fields: [locationId], references: [id])
  device     Device?   @relation(fields: [deviceId], references: [id])
  createdBy  User      @relation("CrmCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User?     @relation("CrmAssignedTo", fields: [assignedToUserId], references: [id])

  @@index([clientId])
  @@index([type])
  @@index([occurredAt])
}

model WorkSession {
  id             String    @id @default(uuid())
  clientId       String
  deviceId       String?
  agentRegId     String?
  techId         String
  ticketId       String?
  locationId     String?
  status         String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  pausedAt       DateTime?
  totalPausedMin Int       @default(0)
  durationMin    Int?
  notes          String?
  createdAt      DateTime  @default(now())

  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  device      Device?            @relation(fields: [deviceId], references: [id])
  tech        User               @relation("WorkSessionTech", fields: [techId], references: [id])
  ticket      Ticket?            @relation(fields: [ticketId], references: [id])
  location    Location?          @relation(fields: [locationId], references: [id])
  timeEntries SessionTimeEntry[]

  @@index([clientId])
  @@index([techId])
  @@index([ticketId])
  @@index([status])
}

model SessionTimeEntry {
  id            String    @id @default(uuid())
  workSessionId String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationMin   Int?
  notes         String?
  createdAt     DateTime  @default(now())

  workSession WorkSession @relation(fields: [workSessionId], references: [id], onDelete: Cascade)

  @@index([workSessionId])
}

model AgentRegistration {
  id             String      @id @default(uuid())
  agentToken     String      @unique @default(uuid())
  status         AgentStatus @default(PENDING)
  nip            String?
  clientId       String?
  deviceId       String?
  assignedUserId String?
  // Sieć / system
  hostname       String?
  ipAddress      String?
  osInfo         String?
  windowsVersion String?
  domain         String?
  currentUser    String?
  serialNumber   String?
  lastBootTime   String?
  // CPU / RAM / GPU
  cpuModel       String?
  cpuCores       Int?
  cpuThreads     Int?
  ramTotalGb     Float?
  gpuModel       String?
  motherboard    String?
  rustdeskId     String?
  // Dane rejestracyjne (z formularza agenta)
  companyName           String?
  contactFirstName      String?
  contactLastName       String?
  contactPhone          String?
  contactEmail          String?
  contactPasswordHash   String?
  registrationNotes     String?
  allowRustdesk       Boolean  @default(true)
  allowMonitoring     Boolean  @default(true)
  // Metryki bieżące
  cpuUsage       Float?
  ramUsage       Float?
  diskFree       Float?
  diskTotal      Float?
  cpuTempC       Float?
  // JSON — dyski, interfejsy sieciowe, zainstalowane programy
  diskInfo            Json?
  networkIfaces       Json?
  installedSoftware   Json?
  managerId      String?
  appVersion     String?
  lastSeen       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  client       Client?  @relation(fields: [clientId], references: [id])
  device       Device?  @relation(fields: [deviceId], references: [id])
  assignedUser  User?    @relation("AgentUser", fields: [assignedUserId], references: [id])
  manager       User?    @relation("DeviceManager", fields: [managerId], references: [id])
  backupConfigs BackupConfig[]
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model BackupConfig {
  id              String   @id @default(uuid())
  agentRegId      String
  clientId        String
  name            String
  type            String   // SQL_MYSQL | SQL_POSTGRES | SQL_MSSQL | FOLDER
  enabled         Boolean  @default(true)
  sqlHost         String?
  sqlPort         Int?
  sqlUser         String?
  sqlPassEnc      String?
  sqlDatabases    String?
  folderPath      String?
  googleDriveFolder String?
  cronSchedule    String   @default("0 2 * * *")
  retentionDays   Int      @default(30)
  encryptBackups  Boolean  @default(true)
  encryptionKey   String?
  lastRunAt       DateTime?
  lastStatus      String?  // SUCCESS | FAILED | RUNNING
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent   AgentRegistration @relation(fields: [agentRegId], references: [id])
  client  Client            @relation(fields: [clientId], references: [id])
  history BackupHistory[]

  @@index([agentRegId])
  @@index([clientId])
}

model BackupHistory {
  id              String    @id @default(uuid())
  backupConfigId  String
  status          String    // RUNNING | SUCCESS | FAILED
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  sizeBytes       BigInt?
  fileName        String?
  googleDriveId   String?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  config BackupConfig @relation(fields: [backupConfigId], references: [id], onDelete: Cascade)

  @@index([backupConfigId])
  @@index([status])
}

model DownloadPinRequest {
  id        String    @id @default(uuid())
  email     String
  pin       String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  DONE
}

model Task {
  id               String     @id @default(uuid())
  taskNumber       String     @unique
  ticketId         String?
  assignedToUserId String
  createdByUserId  String
  title            String
  description      String?
  status           TaskStatus @default(NEW)
  dueAt            DateTime?
  completedAt      DateTime?
  notes            String?
  travelKm         Float?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  ticket     Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignedTo User    @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id])
  createdBy  User    @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
}

model ClientFavorite {
  id        String   @id @default(uuid())
  userId    String
  clientId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

enum OrderStatus {
  NEW
  PENDING_APPROVAL
  IN_PROGRESS
  INSTALLED
  CANCELLED
}

model Order {
  id               String      @id @default(uuid())
  orderNumber      String      @unique
  clientId         String
  ticketId         String?
  createdByUserId  String
  assignedToUserId String?
  status           OrderStatus @default(NEW)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ticket     Ticket?     @relation(fields: [ticketId], references: [id])
  createdBy  User        @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User?       @relation("OrderAssignedTo", fields: [assignedToUserId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  name           String
  price          Float?
  quantity       Int      @default(1)
  link           String?
  addToInventory Boolean  @default(false)
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Delegation {
  id               String    @id @default(uuid())
  delegationNumber String    @unique
  clientId         String
  createdByUserId  String
  assignedToUserId String?
  title            String
  description      String?
  scheduledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy  User   @relation("DelegationCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User?  @relation("DelegationAssignedTo", fields: [assignedToUserId], references: [id])
}
