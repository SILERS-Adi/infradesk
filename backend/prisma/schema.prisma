}

model BackupConfig {
  id                String    @id @default(uuid())
  workspaceId       String
  agentRegId        String
  name              String
  type              String // SQL_MYSQL | SQL_POSTGRES | SQL_MSSQL | FOLDER
  enabled           Boolean   @default(true)
  sqlHost           String?
  sqlPort           Int?
  sqlUser           String?
  sqlPassEnc        String?
  sqlDatabases      String?
  folderPath        String?
