  itemsChecked Json?
  notes        String?
  startedAt    DateTime             @default(now())
  completedAt  DateTime?
  workspaceId  String

  shipment  Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  workspace Workspace      @relation("PackingSessionWorkspace", fields: [workspaceId], references: [id])
  photos    PackingPhoto[]

  @@index([shipmentId])
  @@index([workspaceId, status])
  @@index([userId])
}

// ── PakOps: Picking Session ────────────────────────────────────────

model PickingSession {
  id          String               @id @default(uuid())
  userId      String
  status      PickingSessionStatus @default(IN_PROGRESS)
  itemsToPick Json?
  orderIds    Json?
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  workspaceId String

  workspace Workspace @relation("PickingSessionWorkspace", fields: [workspaceId], references: [id])

  @@index([workspaceId, status])
  @@index([userId])
}

// ── PakOps: Packing Batch ──────────────────────────────────────────

model PackingBatch {
  id          String             @id @default(uuid())
  name        String
  mode        PackingBatchMode   @default(DATE)
  courierName String?
  courierId   String?
  status      PackingBatchStatus @default(OPEN)
  takenById   String?
  workspaceId String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace           @relation("PackingBatchWorkspace", fields: [workspaceId], references: [id])
  orders    PackingBatchOrder[]

  @@index([workspaceId, status])
}

model PackingBatchOrder {
  id         String @id @default(uuid())
  batchId    String
  shipmentId String

  batch    PackingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  shipment Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([batchId, shipmentId])
  @@index([batchId])
  @@index([shipmentId])
}

// ── PakOps: Courier & Carrier ──────────────────────────────────────

model Courier {
  id            String   @id @default(uuid())
  name          String
  logoUrl       String?
  pickupTime    String?
  worksSaturday Boolean  @default(false)
  isActive      Boolean  @default(true)
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation("CourierWorkspace", fields: [workspaceId], references: [id])
  carriers  Carrier[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model Carrier {
  id          String   @id @default(uuid())
  name        String
  code        String?
  pickupTime  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  courierId   String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courier   Courier?  @relation(fields: [courierId], references: [id], onDelete: SetNull)
  workspace Workspace @relation("CarrierWorkspace", fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([courierId])
}

// ── PakOps: Packing Photo ──────────────────────────────────────────

model PackingPhoto {
  id          String   @id @default(uuid())
  sessionId   String
  filename    String
  contentType String   @default("image/jpeg")
  data        Bytes
  createdAt   DateTime @default(now())

  session PackingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ── PakOps: Allegro Integration ────────────────────────────────────

model AllegroAccount {
  id                    String             @id @default(uuid())
  name                  String
  clientId              String
  clientSecretEncrypted String
  redirectUri           String?
  environment           AllegroEnvironment @default(PRODUCTION)
  isActive              Boolean            @default(true)
  workspaceId           String
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  workspace Workspace      @relation("AllegroAccountWorkspace", fields: [workspaceId], references: [id])
  tokens    AllegroToken[]
  syncLogs  SyncLog[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model AllegroToken {
  id                    String   @id @default(uuid())
  accountId             String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenType             String   @default("bearer")
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  account AllegroAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

// ── PakOps: Sync Log ───────────────────────────────────────────────

model SyncLog {
  id           String     @id @default(uuid())
  accountId    String
  syncType     SyncType
  status       SyncStatus @default(RUNNING)
  itemsSynced  Int        @default(0)
  errorMessage String?
  startedAt    DateTime   @default(now())
  finishedAt   DateTime?
  workspaceId  String

  account   AllegroAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workspace Workspace      @relation("SyncLogWorkspace", fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([accountId, syncType])
  @@index([startedAt])
}

// ── PakOps: Shipment Status History ────────────────────────────────

model ShipmentStatusHistory {
  id          String   @id @default(uuid())
  shipmentId  String
  oldStatus   String?
  newStatus   String
  changedById String?
  note        String?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([createdAt])
}

model PackingOrder {
  id               String             @id @default(uuid())
  workspaceId      String
  externalOrderId  String?
  status           PackingOrderStatus @default(NEW)
  paymentStatus    String             @default("pending")
  totalAmount      Decimal            @default(0)
  currency         String             @default("PLN")
  buyerNote        String?
  internalNote     String?
  addressName      String?
  addressStreet    String?
  addressCity      String?
  addressZip       String?
  addressPhone     String?
  deliveryMethod   String?
  deliveryPointId  String?
  courierName      String?
  trackingNumber   String?
  dispatchDeadline DateTime?
  paidAt           DateTime?
  shippedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  items PackingOrderItem[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model PackingOrderItem {
  id        String  @id @default(uuid())
  orderId   String
  name      String
  sku       String?
  quantity  Int     @default(1)
  unitPrice Decimal @default(0)
  imageUrl  String?

  order PackingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

enum PackingOrderStatus {
  NEW
  PAID
  PICKING
  PICKED
  PACKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

// ── Service Module (SKP / Serwis) ───────────────────────────────────

model ServiceVehicle {
  id          String   @id @default(uuid())
  workspaceId String
  plate       String
  vin         String?
  brand       String
  model       String
  year        Int?
  ownerName   String
  ownerPhone  String?
  ownerEmail  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inspections ServiceInspection[]

  @@index([workspaceId])
  @@index([workspaceId, plate])
}

model ServiceInspection {
  id               String                   @id @default(uuid())
  workspaceId      String
  vehicleId        String
  inspectionNumber String
  type             ServiceInspectionType    @default(PERIODIC)
  status           ServiceInspectionStatus  @default(SCHEDULED)
  result           ServiceInspectionResult?
  scheduledAt      DateTime
  completedAt      DateTime?
  technicianName   String?
  notes            String?
  mileage          Int?
  createdById      String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  vehicle ServiceVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, scheduledAt])
  @@index([vehicleId])
}

enum ServiceInspectionType {
  PERIODIC
  TECHNICAL
  GAS_INSTALLATION
  ADR
  TAXI
  OTHER
}

enum ServiceInspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceInspectionResult {
  POSITIVE
  NEGATIVE
  CONDITIONAL
}

// ── Monitoring ──────────────────────────────────────────────────────

model MetricsSnapshot {
  id         String   @id @default(uuid())
  agentRegId String
  type       String   // "audit" | "network" | "health"
  data       Json
  score      Int?
  createdAt  DateTime @default(now())

  agent AgentRegistration @relation(fields: [agentRegId], references: [id], onDelete: Cascade)

  @@index([agentRegId, type, createdAt])
}

model MonitoringAlert {
  id          String   @id @default(uuid())
  workspaceId String
  agentRegId  String
  type        String   // "score_drop" | "critical_fail" | "disk_failing" | "service_down"
  severity    String   // "critical" | "high" | "medium"
  message     String
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace         @relation("AlertWorkspace", fields: [workspaceId], references: [id])
  agent     AgentRegistration @relation("AlertAgent", fields: [agentRegId], references: [id], onDelete: Cascade)

  @@index([workspaceId, resolved, createdAt])
}
