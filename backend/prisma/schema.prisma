  id         String  @id @default(uuid())
  documentId String
  name       String
  quantity   Decimal @default(1)
  priceNet   Decimal @default(0)
  vatRate    String  @default("23")
  totalNet   Decimal @default(0)
  totalVat   Decimal @default(0)
  totalGross Decimal @default(0)

  document InvoiceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

enum InvoiceDocumentType {
