// ── Packaging Module ────────────────────────────────────────────────

model Shipment {
  id             String         @id @default(uuid())
  workspaceId    String
  orderNumber    String
  customerName   String
  customerEmail  String?
  customerPhone  String?
  status         ShipmentStatus @default(NEW)
  courier        String         @default("inpost")
  trackingNumber String?
  totalWeight    Int            @default(0)
  notes          String?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // PakOps extended fields
  externalId       String?
  source           ShipmentSource?
  paymentStatus    String?
  totalAmount      Float?
  currency         String?         @default("PLN")
  codAmount        Float?
  deliveryCost     Float?
  buyerNote        String?
  internalNote     String?
  addressName      String?
  addressStreet    String?
  addressCity      String?
  addressZip       String?
  addressPhone     String?
  addressCountry   String?         @default("PL")
  deliveryMethod   String?
  deliveryPointId  String?
  paidAt           DateTime?
  shippedAt        DateTime?
  dispatchDeadline DateTime?
  wantsInvoice     Boolean?        @default(false)
  invoiceCompany   String?
  invoiceNip       String?
  invoiceAddress   String?
  customerId       String?

  items           ShipmentItem[]
  customer        PackingCustomer?        @relation(fields: [customerId], references: [id])
  packingSessions PackingSession[]
  batchOrders     PackingBatchOrder[]
  statusHistory   ShipmentStatusHistory[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([externalId])
  @@index([customerId])
}

model ShipmentItem {
  id             String  @id @default(uuid())
  shipmentId     String
  name           String
  sku            String?
  quantity       Int     @default(1)
  weight         Int     @default(0)
  unitPrice      Decimal @default(0) @db.Decimal(12, 2)
  totalPrice     Decimal @default(0) @db.Decimal(12, 2)
  allegroOfferId String?
  imageUrl       String?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

enum ShipmentStatus {
  NEW
  PAID
  PICKING
  PICKED
  PACKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  ERROR
  PENDING
}

enum ShipmentSource {
  ALLEGRO
  MANUAL
  API
}

enum PackingSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PickingSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PackingBatchMode {
  DATE
  COURIER
}

enum PackingBatchStatus {
  OPEN
  PICKING
  PACKED
  READY
  COMPLETED
  CANCELLED
}

enum AllegroEnvironment {
  PRODUCTION
  SANDBOX
}

enum SyncType {
  ORDERS
  OFFERS
  RETURNS
  FULL
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ── PakOps: Customer ───────────────────────────────────────────────

model PackingCustomer {
  id            String    @id @default(uuid())
  workspaceId   String
  allegroUserId String?
  login         String?
  email         String?
  firstName     String?
  lastName      String?
  companyName   String?
  phone         String?
  addressStreet String?
  addressCity   String?
  addressZip    String?
  nip           String?
  notes         String?
  totalOrders   Int       @default(0)
  totalSpent    Decimal   @default(0)  @db.Decimal(12, 2)
  firstOrderAt  DateTime?
  lastOrderAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace  @relation("PackingCustomerWorkspace", fields: [workspaceId], references: [id])
  shipments Shipment[]

  @@unique([workspaceId, allegroUserId])
  @@index([workspaceId])
  @@index([workspaceId, email])
}

// ── PakOps: Packing Session ────────────────────────────────────────

model PackingSession {
  id           String               @id @default(uuid())
  shipmentId   String
  userId       String
