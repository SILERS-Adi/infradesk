generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  BROKEN
  RETIRED
  IN_SERVICE
}

enum DeviceCriticality {
  LOW
  MEDIUM
  HIGH
}

enum CredentialCategory {
  ROUTER
  SERVER
  WINDOWS
  EMAIL
  VPN
  WIFI
  DOMAIN
  NAS
  CAMERA
  OTHER
}

enum TicketType {
  INCIDENT
  REQUEST
  MAINTENANCE
  INSTALLATION
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  NEW
  PENDING
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESOLVED
  CLOSED
  COMPLETED
  CANCELLED
}

enum TicketSource {
  CLIENT_PORTAL
  INTERNAL
  PHONE
  EMAIL
  QR_SCAN
  AGENT
  IN_PERSON
  MESSAGE
}

enum AgentStatus {
  PENDING
  ACTIVE
  REJECTED
}

// ── Workspace model ─────────────────────────────────────────────────

enum WorkspaceType {
  PERSONAL
  COMPANY
  MSP
}

enum WorkspacePlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  TECHNICIAN
  MEMBER
  VIEWER
}

enum ScopeType {
  FULL
  SCOPED
}

enum MembershipSource {
  DIRECT
  MSP_ASSIGNED
  INVITATION
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REVOKED
}

enum ManagementStatus {
  ACTIVE
  SUSPENDED
  DETACHED
}

enum ManagementAccess {
  FULL_MANAGEMENT
  REMOTE_SUPPORT
  MONITORING_ONLY
}

enum GrantResourceType {
  LOCATION
  DEVICE
}

// ── Canonical workspace configuration enums ─────────────────────────

/// Canonical source of truth for workspace type. Replaces organizationType string.
enum OrganizationType {
  CLIENT
  INTERNAL_IT
  MSP
}

/// Closed catalog of available modules. Used as enum to prevent typos.
enum ModuleKey {
  INFRASTRUCTURE
  SERVICE_DESK
  INVOICING
  PACKAGING
  SKP
  AI
}

/// Real system states only. PLANNED_ENABLE / PLANNED_DISABLE are frontend/preview-only.
enum ModuleState {
  ACTIVE
  TRIAL
  INACTIVE
  LIMITED
  READONLY
  MANAGED_BY_PROVIDER
  EXPIRED
}

enum PlatformBillingMode {
  SELF
  PROVIDER
}

enum AccountManagedBy {
  SELF
  PROVIDER
}

enum DetachPolicy {
  ALLOWED
  APPROVAL_REQUIRED
  BLOCKED
}

// ── SuperAdmin global config ────────────────────────────────────────
model PlatformConfig {
  id                   String   @id @default("global")
  // Stawki pomocy zdalnej
  remoteHelpBasePrice  Float    @default(89)
  remoteHelpHourlyRate Float    @default(120)
  remoteHelpCurrency   String   @default("PLN")
  // Bramka płatności (mBank/imoje)
  paymentGateway       String   @default("imoje")
  paymentMerchantId    String?
  paymentServiceId     String?
  paymentApiKey        String?
  paymentEnabled       Boolean  @default(false)
  // Email — Powiadomienia
  notifySmtpHost       String?
  notifySmtpPort       Int?     @default(587)
  notifySmtpUser       String?
  notifySmtpPass       String?
  notifySmtpFrom       String?
  notifySmtpFromName   String?  @default("InfraDesk")
  // Email — Alerty
  alertSmtpHost        String?
  alertSmtpPort        Int?     @default(587)
  alertSmtpUser        String?
  alertSmtpPass        String?
  alertSmtpFrom        String?
  alertSmtpFromName    String?  @default("InfraDesk Alert")
  // Google Drive API (OAuth2 for backups)
  googleClientId       String?
  googleClientSecret   String?
  // Ogólne
  platformName         String   @default("InfraDesk")
  supportEmail         String?
  supportPhone         String?
  updatedAt            DateTime @updatedAt
}

// ── Workspace ───────────────────────────────────────────────────────

model Workspace {
  id   String        @id @default(uuid())
  name String
  slug String        @unique
  type WorkspaceType
  plan WorkspacePlan @default(FREE)

  legalName    String?
  taxId        String?
  email        String?
  phone        String?
  website      String?
  addressLine1 String?
  postalCode   String?
  city         String?
  country      String  @default("PL")
  logoUrl      String?
  primaryColor String? @default("#6D28D9")

  maxAgents      Int      @default(10)
  maxUsers       Int      @default(5)
  enabledModules String[] @default(["infrastructure", "service-desk"]) // @deprecated — use WorkspaceModule table. Kept as fallback for migration period.

  // Subscription
  subscriptionStatus String    @default("TRIAL") // TRIAL | ACTIVE | EXPIRED | PAUSED
  trialEndDate       DateTime?
  billingCycle       String    @default("MONTHLY") // MONTHLY | YEARLY
  monthlyPrice       Float     @default(0)
  lastConfig         Json? // saved configurator state for renewal
  paidUntil          DateTime?

  // Multi-tenant organization type
  organizationType String @default("internal_it") // LEGACY — kept in sync by syncLegacyFields()

  // ── Canonical config (new) ──
  /// Canonical source of truth for org type. organizationType (String) is legacy — kept in sync.
  orgType             OrganizationType   @default(INTERNAL_IT)
  /// Billing & management — dotyczą domyślnej relacji helpdeskowej / domyślnego providera.
  /// UWAGA ARCHITEKTONICZNA: w przyszłości przy wielu providerach mogą
  /// przenieść się do WorkspaceRelation. Na razie prościej na Workspace.
  platformBillingMode PlatformBillingMode @default(SELF)
  accountManagedBy    AccountManagedBy   @default(SELF)
  detachPolicy        DetachPolicy       @default(ALLOWED)

  workspaceKey String   @unique @default(uuid())
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships        WorkspaceMembership[]
  managedBy          WorkspaceManagement[] @relation("ManagedCompany")
  manages            WorkspaceManagement[] @relation("ManagingMsp")
  settings           WorkspaceSetting[]
  locations          Location[]            @relation("LocationWorkspace")
  devices            Device[]              @relation("DeviceWorkspace")
  tickets            Ticket[]              @relation("TicketWorkspace")
  ticketsRequested   Ticket[]              @relation("TicketRequesterWorkspace")
  ticketsProvided    Ticket[]              @relation("TicketProviderWorkspace")
  credentials        Credential[]          @relation("CredentialWorkspace")
  agents             AgentRegistration[]   @relation("AgentWorkspace")
  tasks              Task[]                @relation("TaskWorkspace")
  workSessions       WorkSession[]         @relation("WorkSessionWorkspace")
  orders             Order[]               @relation("OrderWorkspace")
  delegations        Delegation[]          @relation("DelegationWorkspace")
  crmActivities      CrmActivity[]         @relation("CrmWorkspace")
  backupConfigs      BackupConfig[]        @relation("BackupWorkspace")
  activityLogs       ActivityLog[]         @relation("ActivityLogWorkspace")
  monitoringAlerts   MonitoringAlert[]     @relation("AlertWorkspace")
  sharingInvitations SharingInvitation[]

  // PakOps relations
  packingCustomers PackingCustomer[] @relation("PackingCustomerWorkspace")
  packingSessions  PackingSession[]  @relation("PackingSessionWorkspace")
  pickingSessions  PickingSession[]  @relation("PickingSessionWorkspace")
  packingBatches   PackingBatch[]    @relation("PackingBatchWorkspace")
  couriers         Courier[]         @relation("CourierWorkspace")
  carriers         Carrier[]         @relation("CarrierWorkspace")
  allegroAccounts  AllegroAccount[]  @relation("AllegroAccountWorkspace")
  syncLogs         SyncLog[]         @relation("SyncLogWorkspace")

  menuPreferences      UserMenuPreference[]  @relation("MenuPrefWorkspace")
  permissionSchemas    PermissionSchema[]    @relation("PermissionSchemaWorkspace")

  // Multi-tenant relations
  clientRelations      WorkspaceRelation[]   @relation("RelationClient")
  providerRelations    WorkspaceRelation[]   @relation("RelationProvider")
  helpdeskSettings     WorkspaceHelpdeskSettings?

  /// Canonical module activation — replaces enabledModules[] flat array.
  modules              WorkspaceModule[]

  // Relations added for workspace isolation completeness
  notifications        Notification[]        @relation("NotificationWorkspace")
  pushSubscriptions    PushSubscription[]    @relation("PushWorkspace")
  techPositions        TechPosition[]        @relation("TechPositionWorkspace")
  subscriptions        Subscription[]        @relation("SubscriptionWorkspace")
  trustedContacts      TrustedContact[]      @relation("TrustedContactWorkspace")
  downloadPinRequests  DownloadPinRequest[]  @relation("DownloadPinWorkspace")

  @@index([type])
  @@index([isActive])
}

model WorkspaceRelation {
  id                       String   @id @default(uuid())
  clientWorkspaceId        String
  providerWorkspaceId      String

  canViewDevices           Boolean  @default(true)
  canViewUsers             Boolean  @default(false)
  canViewLocations         Boolean  @default(true)
  canReceiveTickets        Boolean  @default(true)
  canCreateTicketsOnBehalf Boolean  @default(true)
  canAccessAlerts          Boolean  @default(true)

  isDefaultHelpdeskProvider Boolean @default(false)

  // Rozliczenia
  billingType              String   @default("hourly") // "subscription" | "hourly"
  subscriptionMonthlyNet   Float?   // kwota netto abonamentu/msc
  subscriptionHours        Int?     // godziny w abonamencie
  overageRate              Float?   // stawka/h po przekroczeniu limitu
  hourlyRate               Float?   // stawka/h (bez abonamentu)
  billingIncrementMin      Int      @default(15) // naliczanie co ile minut
  billingPeriod            String   @default("monthly") // "monthly" | "quarterly" | "yearly"
  contractFileUrl          String?  // URL skanu umowy (upload)

  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientWorkspace   Workspace @relation("RelationClient", fields: [clientWorkspaceId], references: [id], onDelete: Cascade)
  providerWorkspace Workspace @relation("RelationProvider", fields: [providerWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([clientWorkspaceId, providerWorkspaceId])
  @@index([clientWorkspaceId])
  @@index([providerWorkspaceId])
}

model WorkspaceHelpdeskSettings {
  id                         String  @id @default(uuid())
  workspaceId                String  @unique

  ticketRoutingMode          String  @default("internal_only") // internal_only | send_to_default_provider | ask_each_time
  defaultProviderWorkspaceId String?
  allowUserProviderSelection Boolean @default(false)
  allowAssistantAutoCreate   Boolean @default(true)
  allowAlertAutoCreate       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

/// Canonical source of truth for module activation per workspace.
/// Replaces the flat Workspace.enabledModules[] string array.
model WorkspaceModule {
  id          String      @id @default(uuid())
  workspaceId String
  moduleKey   ModuleKey
  state       ModuleState @default(ACTIVE)
  activatedAt DateTime    @default(now())
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, moduleKey])
  @@index([workspaceId])
}

model UserMenuPreference {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  layout      Json
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation("MenuPrefWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model WorkspaceMembership {
  id             String           @id @default(uuid())
  userId         String
  workspaceId    String
  role           MemberRole       @default(MEMBER)
  scopeType      ScopeType        @default(FULL)
  source         MembershipSource @default(DIRECT)
  allowedModules Json?
  isDefault      Boolean          @default(false)
  status         MembershipStatus @default(ACTIVE)
  managementId   String?

  // Permission model v2
  accountType    String           @default("USER")       // @deprecated — use role instead. Kept for permission UI backward compat.
  accessScope    String           @default("FULL")       // @deprecated — use scopeType instead. Kept for permission UI backward compat.

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user                 User                      @relation(fields: [userId], references: [id])
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id])
  management           WorkspaceManagement?      @relation(fields: [managementId], references: [id])
  accessGrants         AccessGrant[]
  permissionOverrides  UserPermissionOverride[]

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@index([status])
}

model UserPermissionOverride {
  id           String  @id @default(uuid())
  membershipId String
  nodeId       String  // hierarchical: "infrastructure", "infrastructure.devices", "invoicing.documents"
  level        String  // "FULL" | "VIEW" | "NONE"
  canDelete    Boolean @default(false)

  membership WorkspaceMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, nodeId])
  @@index([membershipId])
}

model AccessGrant {
  id           String            @id @default(uuid())
  membershipId String
  resourceType GrantResourceType
  resourceId   String

  membership WorkspaceMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, resourceType, resourceId])
  @@index([membershipId])
  @@index([resourceType, resourceId])
}

model PermissionSchema {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  description String?
  overrides   Json     // { nodeId, level, canDelete }[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation("PermissionSchemaWorkspace", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// @deprecated Legacy MSP management model. Use WorkspaceRelation instead.
/// Kept for backward compatibility — do NOT add new features here.
model WorkspaceManagement {
  id                 String @id @default(uuid())
  mspWorkspaceId     String
  companyWorkspaceId String

  status      ManagementStatus @default(ACTIVE)
  accessLevel ManagementAccess @default(FULL_MANAGEMENT)

  contractType         String?   // UNLIMITED | HOURLY | MONTHLY | YEARLY
  contractHours        Int?
  contractMonthlyValue Float?
  hourlyRate           Float?
  contractScope        String?
  contractStartDate    DateTime?
  contractEndDate      DateTime?
  billedToMsp          Boolean   @default(true)

  detachedAt       DateTime?
  detachedByUserId String?
  detachReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mspWorkspace     Workspace             @relation("ManagingMsp", fields: [mspWorkspaceId], references: [id])
  companyWorkspace Workspace             @relation("ManagedCompany", fields: [companyWorkspaceId], references: [id])
  memberships      WorkspaceMembership[]

  @@unique([mspWorkspaceId, companyWorkspaceId])
  @@index([mspWorkspaceId])
  @@index([companyWorkspaceId])
  @@index([status])
}

model WorkspaceSetting {
  id          String   @id @default(uuid())
  workspaceId String
  key         String
  value       String
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// ────────────────────────────────────────────────────────────────────

enum CrmActivityType {
  PHONE
  EMAIL
  MEETING
  QUOTE
}

enum QuoteStatus {
  NEW
  PREPARING
  SENT
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  email                String    @unique
  phone                String?
  passwordHash         String
  isActive             Boolean   @default(true)
  isSuperAdmin         Boolean   @default(false)
  emailVerified        Boolean   @default(false)
  notificationSettings Json?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  downloadPin    String?
  avatarUrl      String?
  tokenVersion   Int       @default(0) // Incremented on logout/password change — invalidates all refresh tokens
  loginAttempts  Int       @default(0) // Failed login counter for account lockout
  lockedUntil    DateTime?             // Account lockout expiry

  workspaceMemberships WorkspaceMembership[]

  createdTickets        Ticket[]            @relation("TicketCreatedBy")
  assignedTickets       Ticket[]            @relation("TicketAssignedTo")
  ratedTickets          Ticket[]            @relation("TicketRatedBy")
  ticketComments        TicketComment[]
  createdCredentials    Credential[]
  activityLogs          ActivityLog[]
  assignedDevices       Device[]            @relation("DeviceAssignedUser")
  assignedCredentials   Credential[]        @relation("CredentialUser")
  createdCrmActivities  CrmActivity[]       @relation("CrmCreatedBy")
  assignedCrmActivities CrmActivity[]       @relation("CrmAssignedTo")
  agentRegistrations    AgentRegistration[] @relation("AgentUser")
  workSessions          WorkSession[]       @relation("WorkSessionTech")
  managedDevices        AgentRegistration[] @relation("DeviceManager")
  managedDevicesDirect  Device[]            @relation("DeviceDirectManager")
  createdTasks          Task[]              @relation("TaskCreatedBy")
  assignedTasks         Task[]              @relation("TaskAssignedTo")
  createdOrders         Order[]             @relation("OrderCreatedBy")
  assignedOrders        Order[]             @relation("OrderAssignedTo")
  createdDelegations    Delegation[]        @relation("DelegationCreatedBy")
  assignedDelegations   Delegation[]        @relation("DelegationAssignedTo")
  techPosition          TechPosition?
  subscriptions         Subscription[]
  trustedContacts       TrustedContact[]
  pushSubscriptions     PushSubscription[]
  notifications         Notification[]      @relation("NotificationRecipient")
  sentNotifications     Notification[]      @relation("NotificationSender")
  menuPreferences       UserMenuPreference[]
}

model TechPosition {
  id              String    @id @default(uuid())
  userId          String    @unique
  workspaceId     String?
  latitude        Float
  longitude       Float
  accuracy        Float?
  nearLocationIds Json?
  updatedAt       DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation("TechPositionWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Location {
  id                 String   @id @default(uuid())
  workspaceId        String
  name               String
  type               String
  addressLine1       String
  addressLine2       String?
  postalCode         String
  city               String
  country            String   @default("PL")
  contactPersonName  String?
  contactPersonPhone String?
  contactPersonEmail String?
  notes              String?
  latitude           Float?
  longitude          Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace     Workspace     @relation("LocationWorkspace", fields: [workspaceId], references: [id])
  devices       Device[]
  credentials   Credential[]
  tickets       Ticket[]
  crmActivities CrmActivity[]
  workSessions  WorkSession[]

  @@index([workspaceId])
}

model DeviceType {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices Device[]
}

model Device {
  id                 String            @id @default(uuid())
  workspaceId        String
  locationId         String
  deviceTypeId       String?
  name               String
  assetTag           String?
  manufacturer       String?
  model              String?
  serialNumber       String?
  hostname           String?
  ipAddress          String?
  macAddress         String?
  operatingSystem    String?
  osVersion          String?
  warrantyUntil      DateTime?
  purchaseDate       DateTime?
  status             DeviceStatus      @default(ACTIVE)
  criticality        DeviceCriticality @default(MEDIUM)
  qrCodeValue        String            @unique @default(uuid())
  description        String?
  internalNotes      String?
  clientVisibleNotes String?
  rustdeskId         String?
  rdpAddress         String?
  sshAddress         String?
  anydeskId          String?
  teamviewerId       String?
  customRemoteLink   String?
  assignedUserId     String?
  installationDate   DateTime?
  warrantyMonths     Int?
  gpsLat             Float?
  gpsLon             Float?
  managerId          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  workspace     Workspace           @relation("DeviceWorkspace", fields: [workspaceId], references: [id])
  manager       User?               @relation("DeviceDirectManager", fields: [managerId], references: [id])
  location      Location            @relation(fields: [locationId], references: [id])
  deviceType    DeviceType?         @relation(fields: [deviceTypeId], references: [id])
  assignedUser  User?               @relation("DeviceAssignedUser", fields: [assignedUserId], references: [id])
  credentials   Credential[]
  tickets       Ticket[]
  crmActivities CrmActivity[]
  agents        AgentRegistration[]
  workSessions  WorkSession[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model AccessType {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  color     String?  @default("#6366f1")
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credentials Credential[]
}

model Credential {
  id                 String             @id @default(uuid())
  workspaceId        String
  locationId         String?
  deviceId           String?
  accessTypeId       String?
  userId             String?
  name               String
  category           CredentialCategory @default(OTHER)
  username           String?
  passwordEncrypted  String
  urlOrHost          String?
  port               Int?
  additionalData     String?
  notes              String?
  isSharedWithClient Boolean            @default(false)

  // Sejf haseł v2
  visibility      String   @default("COMPANY")  // PRIVATE | COMPANY | SHARED
  programName     String?
  programCategory String?  // BROWSER | EMAIL | ERP | SYSTEM | OTHER
  importSource    String?  // MANUAL | CSV | AGENT
  importedAt      DateTime?
  windowsAccount  Boolean  @default(false)

  createdByUserId    String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace  Workspace   @relation("CredentialWorkspace", fields: [workspaceId], references: [id])
  location   Location?   @relation(fields: [locationId], references: [id])
  device     Device?     @relation(fields: [deviceId], references: [id])
  createdBy  User        @relation(fields: [createdByUserId], references: [id])
  accessType AccessType? @relation(fields: [accessTypeId], references: [id])
  user       User?       @relation("CredentialUser", fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, visibility])
}

model Ticket {
  id                    String         @id @default(uuid())
  ticketNumber          String
  workspaceId           String
  requesterWorkspaceId  String?        // firma zgłaszająca (null = wewnętrzne)
  providerWorkspaceId   String?        // firma obsługująca (null = wewnętrzne)
  locationId            String
  deviceId              String?
  createdByUserId       String
  assignedToUserId      String?
  type              TicketType     @default(INCIDENT)
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus   @default(PENDING)
  source            TicketSource   @default(INTERNAL)
  title             String
  description       String
  resolutionSummary String?
  reportedAt        DateTime       @default(now())
  dueAt             DateTime?
  resolvedAt        DateTime?
  closedAt          DateTime?
  billedInContract  Boolean        @default(false)
  serviceMode       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  reporterName      String?
  reporterPhone     String?

  // Customer satisfaction rating (1-3 stars)
  rating            Int?
  ratingComment     String?
  ratedAt           DateTime?
  ratedByUserId     String?

  workspace     Workspace       @relation("TicketWorkspace", fields: [workspaceId], references: [id])
  location      Location        @relation(fields: [locationId], references: [id])
  device        Device?         @relation(fields: [deviceId], references: [id])
  createdBy     User            @relation("TicketCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo    User?           @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id])
  comments      TicketComment[]
  tasks         Task[]
  orders        Order[]
  workSessions  WorkSession[]
  crmActivities CrmActivity[]   @relation("CrmLinkedTicket")

  requesterWorkspace Workspace? @relation("TicketRequesterWorkspace", fields: [requesterWorkspaceId], references: [id], onDelete: SetNull)
  providerWorkspace  Workspace? @relation("TicketProviderWorkspace", fields: [providerWorkspaceId], references: [id], onDelete: SetNull)
  ratedByUser        User?      @relation("TicketRatedBy", fields: [ratedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, ticketNumber])
  @@index([workspaceId])
  @@index([requesterWorkspaceId])
  @@index([providerWorkspaceId])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
