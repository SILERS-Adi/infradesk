# Vite env example. Skopiuj do `.env.production` (gitignored) na prod build.
# Wszystkie VITE_* są bundled w client-side JS — używaj tylko publicznych wartości.

# Sentry — error tracking (DSN to publiczny klucz, OK w bundlu)
# VITE_SENTRY_DSN=https://<key>@o<orgid>.ingest.de.sentry.io/<projectid>
# VITE_SENTRY_ENV=production
# VITE_SENTRY_TRACES_RATE=0.1

# API — domyślnie absolutny path /api/v2 (przez nginx). Override gdy frontend
# jest na innej domenie niż backend.
# VITE_API_URL=https://infradesk.pl
