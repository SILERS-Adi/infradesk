# ──────────────────────────────────────────────────────────────────────────
# InfraDesk v2 backend — environment variables (example)
# ──────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4200
LOG_LEVEL=debug

# Database (Postgres + pgvector)
DATABASE_URL="postgresql://infradesk_v2:changeme@localhost:5432/infradesk_v2?schema=public"

# Redis (BullMQ + rate limiting + session cache)
REDIS_URL="redis://localhost:6379"

# JWT / Auth
JWT_ACCESS_SECRET="change-me-32-chars-min-for-dev-only"
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_SECRET="change-me-also-32-chars-min-for-dev"
JWT_REFRESH_TTL_DAYS=30
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Argon2 (password hashing)
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Rate limiting
RATE_LIMIT_LOGIN_PER_15MIN=10
RATE_LIMIT_GLOBAL_PER_MIN=120

# AI / LLM
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_MODEL_COPILOT=claude-opus-4-7
LLM_MODEL_CLASSIFY=claude-haiku-4-5-20251001
LLM_MAX_TOKENS_DEFAULT=4096

# Vault (AES-256-GCM)
VAULT_MASTER_KEY="generate-with-openssl-rand-base64-32"

# Email (SMTP)
SMTP_HOST=poczta23159.e-kei.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=powiadomienia@kscsystem.pl
SMTP_PASS=changeme
SMTP_FROM="InfraDesk <powiadomienia@kscsystem.pl>"

# KSeF (Polish e-invoicing) — post-MVP
KSEF_ENV=test
KSEF_TOKEN=

# Polish integrations
GUS_REGON_API_KEY=
